# Site Configuration
SITE_URL=http://localhost:3000

# Optional persistent storage. Without these, dev uses in-memory storage.
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Production safety. Keep false unless intentionally running local/dev memory storage.
ALLOW_MEMORY_STORAGE=false

# Set true only when the app is behind a trusted reverse proxy that overwrites X-Forwarded-For.
TRUST_PROXY=false

# Paste Configuration
MAX_PASTE_SIZE=102400
MAX_REQUEST_BODY_SIZE=262144

# Rate Limiting
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=3600
